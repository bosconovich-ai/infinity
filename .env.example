COMPOSE_PROJECT_NAME=idea-factory
HOST_UID=1000
HOST_GID=1000
APP_PORT=8000
HOST_PORT=18000
IDEA_STORAGE_ROOT=/data/ideas
OPENROUTER_MODEL=qwen/qwen3.5-397b-a17b
OPENROUTER_IDEATION_TEMPERATURE=1.15
ENABLE_MARKET_SCRAPING=1
MARKET_SIGNAL_LIMIT_PER_DOMAIN=2
MARKET_SIGNAL_REFRESH_LIMIT_PER_DOMAIN=8
MARKET_SIGNAL_REFRESH_INTERVAL_SECONDS=900
